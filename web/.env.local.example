# ----------------------------------------------------------------------------
# Hermes gateway -- printed by `npm run deploy`. Server-only (never
# NEXT_PUBLIC_*) so the bearer token never reaches the browser.
# ----------------------------------------------------------------------------
HERMES_API_URL=https://your-tunnel.trycloudflare.com/v1
HERMES_API_KEY=hp-replace-me
HERMES_MODEL=hermes-agent

# ----------------------------------------------------------------------------
# Dedalus -- the dashboard reads machine state via the controlplane REST API.
# `DEDALUS_API_KEY` is the same key that provisions machines (see root .env).
# `HERMES_MACHINE_ID` is printed by `npm run deploy` (also in .machine-state.json).
# ----------------------------------------------------------------------------
DEDALUS_API_KEY=dsk-live-replace-me
DEDALUS_BASE_URL=https://dcs.dedaluslabs.ai
HERMES_MACHINE_ID=dm-replace-me

# ----------------------------------------------------------------------------
# Clerk -- gates /dashboard/* and /api/dashboard/*. Configure the email
# allowlist under "User & Authentication -> Restrictions" in the Clerk
# dashboard. Both keys come from https://dashboard.clerk.com -> API Keys.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
