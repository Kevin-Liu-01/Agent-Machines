# =============================================================================
# Agent Machines — web dashboard env. Copy to `web/.env.local` and fill in.
#
# Next.js loads this from the web/ app root. Anything prefixed NEXT_PUBLIC_ is
# exposed to the browser; everything else is server-only.
#
# WHAT GOES HERE vs IN THE APP:
#   - Auth, Supabase, the scheduler secret, and owner-level provider fallbacks
#     live here (below).
#   - Per-user LLM + sandbox keys (Anthropic, OpenAI, OpenRouter, Google, E2B,
#     Sprites, Cursor) are entered in the dashboard under Settings and stored
#     per account — they are NOT required here. The env vars below are only the
#     project-owner FALLBACKS used when a logged-in user hasn't set their own.
#
# MINIMUM TO RUN LOCALLY OUT OF THE BOX:
#   ALLOW_DEV_AUTH=1  (+ run with `pnpm dev`, which sets NODE_ENV=development)
#   NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY  (metrics/usage/persistence)
#   CRON_SECRET                                           (crons + background tracking)
#   One sandbox provider key (Dedalus below, or E2B/Sprites/Vercel via Settings)
#   One LLM key (Dedalus below routes 200+ models, or set Anthropic/OpenAI in Settings)
# =============================================================================


# -----------------------------------------------------------------------------
# AUTH — Clerk. REQUIRED in production/preview (gates /dashboard/* and
# /api/dashboard/*). For local dev you can skip these and use ALLOW_DEV_AUTH=1.
# Get both keys at https://dashboard.clerk.com → API Keys. Restrict sign-ups
# under User & Authentication → Restrictions.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me


# -----------------------------------------------------------------------------
# LOCAL DEV AUTH BYPASS. When `1` AND NODE_ENV=development (i.e. `pnpm dev`),
# every protected route is treated as signed in under a synthetic `dev-user`,
# and config reads/writes go to web/.dev-user-config.json instead of Clerk.
# Production/preview ignore this (NODE_ENV != development). Set to 1 to run the
# whole dashboard locally without configuring Clerk.
# -----------------------------------------------------------------------------
ALLOW_DEV_AUTH=1


# -----------------------------------------------------------------------------
# SUPABASE — REQUIRED for durable machines, metrics, resource utilization,
# activity timeline, usage/cost rollups, and benchmarks. Without it the app
# falls back to Clerk metadata only and those panels stay empty.
# Project URL + service-role (secret) key from your Supabase project settings.
# The anon key is optional (only needed if we add client-side realtime later).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me


# -----------------------------------------------------------------------------
# SCHEDULER — CRON_SECRET. REQUIRED for the background scheduler
# (/api/internal/cron/tick), which fires scheduled crons AND collects
# usage/activity metrics every tick. In production, Vercel Cron (see
# web/vercel.json, runs */5) calls the tick with this secret as a bearer token.
# Generate one with:  openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=replace_me_openssl_rand_hex_32


# -----------------------------------------------------------------------------
# SANDBOX PROVIDERS (owner-level fallback). Each logged-in user normally sets
# their own provider keys in Settings; these are the project-owner defaults.
#
# Dedalus — Firecracker microVMs with sleep/wake. The same key provisions
# machines AND authenticates LLM inference (OpenAI-compatible, 200+ models),
# so it doubles as your LLM key for Hermes/OpenClaw. https://dedaluslabs.ai
DEDALUS_API_KEY=dsk-live-replace-me
DEDALUS_BASE_URL=https://dcs.dedaluslabs.ai
#
# Vercel Sandbox — provide a token + team + project, OR rely on VERCEL_OIDC_TOKEN
# (auto-injected on Vercel deploys). Tokens: https://vercel.com/account/tokens
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=
# VERCEL_OIDC_TOKEN=          # usually set automatically by Vercel
#
# E2B and Sprites have NO env fallback — add those keys in the dashboard
# Settings page (https://e2b.dev , https://sprites.dev).


# -----------------------------------------------------------------------------
# LLM INFERENCE (owner-level fallback). Per-user keys are set in Settings;
# these are owner defaults.
#
# Vercel AI Gateway key — used as a router upstream when configured.
# AI_GATEWAY_API_KEY=
#
# Anthropic / OpenAI / OpenRouter / Google keys are NOT read from env — set them
# per account in the dashboard Settings page:
#   - Claude Code requires a native Anthropic key
#   - Codex requires a native OpenAI key
#   - Hermes / OpenClaw run on any router (Dedalus above is the zero-config path)
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# OPTIONAL INTEGRATIONS
# -----------------------------------------------------------------------------
# Cursor SDK key — enables the cursor_agent MCP delegation + Cursor runs.
# Owner fallback; users can also set it in Settings. https://cursor.com/dashboard
# CURSOR_API_KEY=
#
# Cloudflare named-tunnel token — only if you want a stable custom-domain gateway.
# Most setups don't need this (providers expose preview URLs).
# CLOUDFLARE_TUNNEL_TOKEN=


# -----------------------------------------------------------------------------
# OPTIONAL — pre-seeded machine (owner fallback). If you already deployed a
# machine via the `npm run deploy` CLI, paste its values so the dashboard
# reports on it before you provision anything in-app. (Legacy HERMES_* names
# still work.) Normally you just provision from the dashboard instead.
# -----------------------------------------------------------------------------
# AGENT_MACHINE_ID=dm-replace-me
# AGENT_API_URL=https://example.trycloudflare.com/v1
# AGENT_API_KEY=hp-replace-me
# AGENT_MODEL=anthropic/claude-sonnet-4-6
# AGENT_VCPU=1
# AGENT_MEMORY_MIB=2048
# AGENT_STORAGE_GIB=10
