# Dedalus Cloud Services. The same key provisions machines (dcs.dedaluslabs.ai)
# and authenticates LLM inference (api.dedaluslabs.ai/v1, OpenAI-compatible),
# so Hermes routes 200+ models without a second key.
DEDALUS_API_KEY=dsk-live-replace-me

# Optional overrides. Defaults match the Dedalus production endpoints.
DEDALUS_BASE_URL=https://dcs.dedaluslabs.ai
DEDALUS_CHAT_BASE_URL=https://api.dedaluslabs.ai/v1

# Default model. Any Dedalus-routable slug works — see
# https://api.dedaluslabs.ai/v1/models for the full catalog.
# Examples: anthropic/claude-sonnet-4-6, openai/gpt-5, google/gemini-2.5-pro, deepseek/deepseek-v3
# (legacy name HERMES_MODEL still works)
AGENT_MODEL=anthropic/claude-sonnet-4-6

# Machine sizing. Dev ceiling is 6144 MiB memory.
# (legacy names HERMES_VCPU / HERMES_MEMORY_MIB / HERMES_STORAGE_GIB still work)
AGENT_VCPU=1
AGENT_MEMORY_MIB=2048
AGENT_STORAGE_GIB=10

# Autosleep. Dedalus machines sleep after ~5 min idle by default.
# Set to 0 or false to install a keepalive cron that prevents autosleep.
# Useful during live-fire testing or long-running bootstrap chains.
# (legacy name HERMES_AUTOSLEEP still works)
AGENT_AUTOSLEEP=true

# Cursor SDK API key (optional but required to use the cursor_agent MCP tool).
# Get one at https://cursor.com/dashboard/integrations or from Team Settings.
# When unset, the rest of the agent works fine; only delegating code work to a
# Cursor agent will fail with a clear error.
CURSOR_API_KEY=cursor_replace_me

# ----------------------------------------------------------------------------
# AI provider keys. Every agent accepts at least one of these.
#
# Hermes accepts ANY OpenAI-compatible endpoint: Dedalus, OpenAI, Anthropic,
# OpenRouter, LiteLLM, Portkey, or a self-hosted gateway. Configure via
# hermes config set model.provider/model.base_url/model.api_key.
#
# OpenClaw mirrors keys to both ANTHROPIC_API_KEY and OPENAI_API_KEY so its
# built-in router picks whichever provider matches the chosen model. When
# using Dedalus, set ANTHROPIC_BASE_URL=https://api.dedaluslabs.ai/v1.
#
# Claude Code requires ANTHROPIC_API_KEY (or a subscription via `claude auth login`).
# Codex CLI requires OPENAI_API_KEY (or a subscription via `codex` login flow).
# ----------------------------------------------------------------------------

# Anthropic API key -- used by Claude Code, OpenClaw, and Hermes (when
# pointed at Anthropic directly). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI API key -- used by Codex CLI, OpenClaw, and Hermes (when
# pointed at OpenAI directly). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# AI Gateway (optional -- use instead of direct provider keys).
# Any OpenAI-compatible gateway works: OpenRouter, LiteLLM, Portkey, RelayPlane, etc.
# Hermes and OpenClaw both support custom endpoints; set these and configure
# the agent's base_url to AI_GATEWAY_URL.
AI_GATEWAY_URL=
AI_GATEWAY_KEY=

# ----------------------------------------------------------------------------
# web/ dashboard. These are read by the Next.js app under web/, NOT the deploy
# CLI. Copy the same DEDALUS_API_KEY above into web/.env.local along with the
# values below, or set them in Vercel project env vars.
# ----------------------------------------------------------------------------

# Clerk auth (https://dashboard.clerk.com -> API Keys). Gates /dashboard/*
# and /api/dashboard/*. Configure the allowlisted emails in the Clerk
# dashboard under "User & Authentication -> Restrictions".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# The machine the dashboard reports on. After `npm run deploy` finishes, the
# CLI prints `Machine ID: dm-...`; copy it here so the overview pulls real
# state without a re-deploy. Also stored in .machine-state.json.
# (legacy name HERMES_MACHINE_ID still works)
AGENT_MACHINE_ID=dm-replace-me

# Agent gateway (printed by `npm run deploy`). The chat + health proxies
# already consume these; the dashboard reuses them.
# (legacy names HERMES_API_URL / HERMES_API_KEY still work)
AGENT_API_URL=https://example.trycloudflare.com/v1
AGENT_API_KEY=hp-replace-me

# Chat history + artifacts now persist on the user's own Dedalus machine
# (under /home/machine/.agent-machines/, on the persistent volume that
# survives sleep/wake). No external blob store needed -- the data lives
# where the agent runs and the agent itself can read it as context.
