{
  "name": "agent-machines",
  "version": "0.2.0",
  "private": true,
  "description": "OpenRouter for agents and containers — control plane for persistent agent workers. Route runtime + substrate, provision specialist presets, supervise the fleet. 161 skills · 35 MCP servers.",
  "type": "module",
  "scripts": {
    "deploy": "tsx src/cli.ts deploy",
    "deploy:openclaw": "tsx src/cli.ts deploy:openclaw",
    "chat": "tsx src/cli.ts chat",
    "status": "tsx src/cli.ts status",
    "logs": "tsx src/cli.ts logs",
    "wake": "tsx src/cli.ts wake",
    "sleep": "tsx src/cli.ts sleep",
    "destroy": "tsx src/cli.ts destroy",
    "shell": "tsx src/cli.ts shell",
    "reload": "tsx src/cli.ts reload-knowledge",
    "reset": "tsx src/cli.ts reset",
    "doctor": "tsx src/cli.ts doctor",
    "gc": "tsx scripts/cleanup-machines.ts",
    "benchmark": "tsx --tsconfig web/tsconfig.json web/scripts/run-benchmarks.ts",
    "sync-wiki": "node scripts/sync-from-wiki.mjs",
    "sync-manifest": "node scripts/sync-knowledge-manifest.mjs",
    "typecheck": "tsc --noEmit",
    "web": "cd web && npm run dev"
  },
  "dependencies": {
    "dedalus": "^0.2.0",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
